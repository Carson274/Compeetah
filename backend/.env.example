# Copy to backend/.env and fill in.  This file holds SECRETS only —
# everyday settings (home/work/users/units) live in ../config.yaml

# Google Maps key for traffic-aware drive time (Distance Matrix API).
# Until set, the commute card shows a friendly "add a key" state.
# https://console.cloud.google.com/  -> enable "Distance Matrix API"
GOOGLE_MAPS_API_KEY=

# Shared secret that OwnTracks must send (as the HTTP Basic password, or
# an "X-Owntracks-Token" header) so randoms can't POST fake locations when
# the endpoint is exposed to the internet. Leave blank to disable the check
# (fine on a trusted LAN; set it before exposing via Tailscale/tunnel).
OWNTRACKS_TOKEN=

# Comma-separated origins allowed to call the API from a browser.
# "*" is fine for a closed home network.
CORS_ORIGINS=*

# Where the SQLite file lives (relative paths are from the repo root).
DATABASE_URL=sqlite:///./data/compeetah.sqlite3

# Host/port for the API + websocket server.
HOST=0.0.0.0
PORT=8000
